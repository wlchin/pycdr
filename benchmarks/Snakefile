configfile: "config.yaml"

N_GENES = config["n_genes"]
N_CELLS = config["n_cells"]
N_PERMS = config["nperm"]
REPS = list(range(1, config["n_repeats"] + 1))


rule all:
    input:
        "figures/benchmark_scaling.png",
        "figures/permutation_scaling.png",
        "results/benchmark_summary.tsv",


rule generate_data:
    output:
        "data/genes{n_genes}_cells{n_cells}.h5ad",
    params:
        n_genes="{n_genes}",
        n_cells="{n_cells}",
        n_phenotypes=config["n_phenotypes"],
        seed=config["seed"],
    script:
        "scripts/generate_synthetic.py"


rule run_benchmark:
    input:
        "data/genes{n_genes}_cells{n_cells}.h5ad",
    output:
        "results/genes{n_genes}_cells{n_cells}_nperm{nperm}_rep{rep}.json",
    params:
        n_genes="{n_genes}",
        n_cells="{n_cells}",
        capvar=config["capvar"],
        nperm="{nperm}",
        thres=config["thres"],
    benchmark:
        "benchmarks_sm/genes{n_genes}_cells{n_cells}_nperm{nperm}_rep{rep}.tsv"
    script:
        "scripts/run_benchmark.py"


rule collect_results:
    input:
        jsons=expand(
            "results/genes{n_genes}_cells{n_cells}_nperm{nperm}_rep{rep}.json",
            n_genes=N_GENES,
            n_cells=N_CELLS,
            nperm=N_PERMS,
            rep=REPS,
        ),
    output:
        "results/benchmark_summary.tsv",
    params:
        benchmark_dir="benchmarks_sm",
    script:
        "scripts/collect_results.py"


rule plot_results:
    input:
        "results/benchmark_summary.tsv",
    output:
        "figures/benchmark_scaling.png",
    script:
        "scripts/plot_benchmark.py"


rule plot_permutation:
    input:
        "results/benchmark_summary.tsv",
    output:
        "figures/permutation_scaling.png",
    script:
        "scripts/plot_permutation.py"
